# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/edu_core?replicaSet=rs0

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_access_token_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_token_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# CORS & Security
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost

# Logging
LOG_LEVEL=info
