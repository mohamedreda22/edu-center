// Prisma schema for Rakan Institute
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/*
 * User Account Management
 * RBAC system with roles: ADMIN, RECEPTIONIST, TEACHER
 */

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String    @unique
  role          UserRole  @default(RECEPTIONIST)
  avatar        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  students      Student[]
  teachers      Teacher[]
  activities    ActivityLog[]

  @@map("users")
}

model Student {
  id                   String         @id @default(cuid())
  userId               String
  studentId            String         @unique
  parentName           String?
  parentPhone          String?
  whatsapp             String?
  area                 String?
  address              String?
  googleMapsUrl        String?
  school               String?
  grade                String         @default("")
  subjects             String         @default("")
  preferredTeacherGender Gender?
  preferredSchedule    String?
  notes                String?
  dateOfBirth          DateTime
  enrollmentDate       DateTime
  status               StudentStatus  @default(ACTIVE)
  gpa                  Float?
  avatar               String?
  monthlyFee           Float          @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  // Relations
  user                 User           @relation(fields: [userId], references: [id])
  lessons              Lesson[]
  payments             Payment[]

  @@map("students")
}

model Teacher {
  id                     String    @id @default(cuid())
  userId                 String
  employeeId             String    @unique
  whatsapp               String?
  civilId                String?
  subjects               String    @default("")
  gradesTaught           String    @default("")
  gender                 Gender?
  nationality            String?
  experience             Int       @default(0)
  address                String?
  googleMapsUrl          String?
  availableDays          String    @default("")    // JSON array: ["Saturday","Sunday",...]
  availableHours         String    @default("")    // e.g. "9:00-13:00, 16:00-20:00"
  ownsCar                Boolean         @default(false)
  transportationAvailable Boolean        @default(false)
  hourlyRate             Float           @default(0)
  rating                 Float?
  notes                  String?
  cvUrl                  String?
  certificatesUrl        String?
  department             String?
  hireDate               DateTime?
  bio                    String?
  avatar                 String?
  isActive               Boolean         @default(true)
  commissionModel        CommissionModel @default(SEVENTY_THIRTY)
  teacherPercentage      Float           @default(0.7)
  institutePercentage    Float           @default(0.3)
  usesInstituteCar       Boolean         @default(false)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  // Relations
  user                   User            @relation(fields: [userId], references: [id])
  lessons                Lesson[]
  salaries               TeacherSalary[]
  payrollRecords         PayrollRecord[]
  payrollTransactions    PayrollTransaction[]

  @@map("teachers")
}

model Lesson {
  id                String        @id @default(cuid())
  studentId         String
  teacherId         String
  title             String
  description       String        @default("")
  dayOfWeek         String        @default("")    // الأحد, الإثنين, ...
  startTime         String        @default("")    // HH:mm
  endTime           String        @default("")    // HH:mm
  durationHours     Int           @default(1)
  lessonDate        DateTime
  status            LessonStatus  @default(SCHEDULED)
  notes             String?
  lessonPrice       Float         @default(0)
  educationalLevel  String?
  teacherPercentage Float         @default(0)
  institutePercentage Float       @default(0)
  teacherEarnings   Float         @default(0)
  instituteRevenue  Float         @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  student             Student              @relation(fields: [studentId], references: [id])
  teacher             Teacher              @relation(fields: [teacherId], references: [id])
  payments            Payment[]
  payrollTransactions PayrollTransaction[]

  @@index([teacherId, lessonDate])
  @@index([studentId, lessonDate])
  @@index([status])
  @@map("lessons")
}

model Payment {
  id            String      @id @default(cuid())
  studentId     String
  lessonId      String?
  amount        Float
  dueDate       DateTime
  paidDate      DateTime?
  status        PaymentStatus @default(PENDING)
  paymentMethod  String?
  transactionId  String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  student       Student  @relation(fields: [studentId], references: [id])
  lesson        Lesson?  @relation(fields: [lessonId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("payments")
}

model ActivityLog {
  id            String    @id @default(cuid())
  userId        String
  action        String
  entityType    String
  entityId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  // Relations
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

// Enums
enum UserRole {
  ADMIN
  RECEPTIONIST
  TEACHER
  ACCOUNTANT
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  WITHDRAWN
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AttendanceStatus {
  COMPLETED
  ABSENT
  CANCELLED
  RESCHEDULED
}

enum CommissionModel {
  SEVENTY_THIRTY
  SIXTYFIVE_THIRTYFIVE
}

model PayrollRecord {
  id                String    @id @default(cuid())
  teacherId         String
  month             Int
  year              Int
  completedLessons  Int       @default(0)
  totalLessonValue  Float     @default(0)
  teacherEarnings   Float     @default(0)
  instituteRevenue  Float     @default(0)
  transportDeductions Float   @default(0)
  finalAmount       Float     @default(0)
  paid              Boolean   @default(false)
  paidDate          DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  teacher    Teacher               @relation(fields: [teacherId], references: [id])
  transactions PayrollTransaction[]

  @@unique([teacherId, month, year])
  @@map("payroll_records")
}

model PayrollTransaction {
  id                  String   @id @default(cuid())
  lessonId            String
  payrollRecordId     String?
  teacherId           String
  userId              String?
  lessonPrice         Float
  teacherPercentage   Float
  institutePercentage Float
  teacherEarnings     Float
  instituteRevenue    Float
  transportDeduction  Float    @default(0)
  action              String   @default("CREATE")
  previousValue       Json?
  newValue            Json?
  createdAt           DateTime @default(now())

  lesson  Lesson         @relation(fields: [lessonId], references: [id])
  teacher Teacher        @relation(fields: [teacherId], references: [id])
  payroll PayrollRecord? @relation(fields: [payrollRecordId], references: [id])

  @@index([lessonId])
  @@index([teacherId])
  @@index([payrollRecordId])
  @@map("payroll_transactions")
}

model TeacherSalary {
  id                      String    @id @default(cuid())
  teacherId               String
  month                   Int
  year                    Int
  lessonsCount            Int       @default(0)
  hoursWorked             Float     @default(0)
  hourlyRate              Float     @default(0)
  transportationAllowance Float     @default(0)
  bonuses                 Float     @default(0)
  deductions              Float     @default(0)
  totalSalary             Float     @default(0)
  paid                    Boolean   @default(false)
  paidDate                DateTime?
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, month, year])
  @@map("teacher_salaries")
}
